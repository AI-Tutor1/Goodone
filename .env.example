# =============================================================================
# Tuitional Finance — environment template
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# ----- Application -----
APP_ENV=development                # development | staging | production
APP_PORT=3002
APP_BASE_URL=http://localhost:3002
SECRET_KEY=                        # generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_LIFETIME_HOURS=8

# ----- Database -----
DATABASE_URL=postgresql+psycopg://tuitional:tuitional@localhost:5432/tuitional
# For tests:
TEST_DATABASE_URL=postgresql+psycopg://tuitional:tuitional@localhost:5432/tuitional_test

# ----- Logging -----
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                    # json | console

# ----- Email (provider abstraction; stubbed in development) -----
EMAIL_PROVIDER=stub                # stub | smtp | sendgrid | ses
EMAIL_FROM_ADDRESS=finance@tuitional.example
EMAIL_FROM_NAME=Tuitional Finance
# SMTP (used if EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
# SendGrid (used if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=
# AWS SES (used if EMAIL_PROVIDER=ses)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ----- LMS adapter -----
LMS_API_BASE_URL=
LMS_API_KEY=
LMS_POLL_INTERVAL_MINUTES=60

# ----- Google Sheets adapter -----
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=  # path to service account JSON
GOOGLE_SHEETS_AD_SPEND_ID=         # spreadsheet ID
GOOGLE_SHEETS_AD_SPEND_TAB=ad_spend

# ----- FX Rate puller -----
FX_API_BASE_URL=https://api.exchangerate.host
FX_API_KEY=                        # optional; exchangerate.host has a free tier
FX_BASE_CURRENCY=AED
FX_TARGET_CURRENCIES=PKR,USD,EUR

# ----- Anthropic API (CFO chat) -----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ----- File storage -----
ATTACHMENTS_DIR=/var/lib/tuitional/attachments
ATTACHMENTS_MAX_SIZE_MB=20

# ----- Backups -----
BACKUP_DIR=/var/backups/tuitional
BACKUP_RETENTION_DAYS=30
BACKUP_OFFSITE_S3_BUCKET=          # optional offsite

# ----- Period close -----
PERIOD_CLOSE_AUTO_CLOSE_DAY=5      # auto-close on T+5 if CFO hasn't acted
PERIOD_CLOSE_AUTO_CLOSE=true

# ----- Capitalization policy -----
CAPITALIZATION_THRESHOLD_AED=1000
TUITIONAL_AI_DEV_MONTHLY_AED=2000
TUITIONAL_AI_FEASIBILITY_DATE=2024-05-01
TUITIONAL_AI_LAUNCH_DATE=           # set when launched

# ----- Frontend -----
FRONTEND_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ----- Observability -----
SENTRY_DSN=                        # optional
PROMETHEUS_METRICS_ENABLED=true
